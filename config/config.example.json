{
  "agents": {
    "defaults": {
      "model_name": "gpt4",
      "max_tokens": 8192,
      "system_prompt": "You are unlimitedClaw, a helpful AI assistant."
    }
  },
  "model_list": [
    {
      "model_name": "gpt4",
      "model": "openai/gpt-4o",
