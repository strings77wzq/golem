      "api_base": "https://api.openai.com/v1"
    },
    {
      "model_name": "claude",
      "model": "anthropic/claude-sonnet-4-20250514",
      "api_key": "${ANTHROPIC_API_KEY}",
      "api_base": "https://api.anthropic.com"
    },
    {
      "model_name": "mock",
      "model": "mock/echo",
      "api_key": ""
    }
  ]
}
